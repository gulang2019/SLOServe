  "extra_server_args": "--ray_address 10.202.0.8:6379 --worker_env NCCL_IB_DISABLE=1,NCCL_NET=Socket,LD_LIBRARY_PATH=/home/siyuanc_google_com/workspace/SLOsServe/.venv/lib/python3.10/site-packages/cv2"
